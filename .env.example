# Google Maps Platform (server-side: Places, Directions)
# Optional if NEXT_PUBLIC_GOOGLE_MAPS_KEY is set — use a separate key in production when possible
GOOGLE_MAPS_API_KEY=

# Google Maps JavaScript API (client-side map rendering; also used as server fallback)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# OpenWeather (optional — falls back to demo data)
OPENWEATHER_API_KEY=

# Optional: Vercel KV / Upstash Redis for distributed caching
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
